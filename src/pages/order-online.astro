---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const thuisbezorgdUrl = '#';
---

<BaseLayout title="Bestellen | Brasserie Pizzeria Hama" description="Bestel online via Thuisbezorgd voor Brasserie Pizzeria Hama in Terneuzen." ogImage="https://nawidh1.github.io/SEO/og/order.jpg">
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Bestellen', href: '/order-online' }]} />
  <PageHero title="Bestellen via Thuisbezorgd" subtitle="Wij nemen geen bestellingen aan via onze eigen website." />
  <section class="section-padding bg-white">
    <div class="container-narrow surface-card p-8 text-center">
      <h2 class="text-2xl">Bestel direct bij Thuisbezorgd</h2>
      <p class="mt-3 text-gray-700">Voor online bestellingen werken wij exclusief met Thuisbezorgd. Zo blijft het bestelproces snel en duidelijk.</p>
      <a href={thuisbezorgdUrl} target="_blank" rel="noopener noreferrer" class="btn-primary mt-6">Ga naar Thuisbezorgd</a>
      <p class="mt-4 text-sm text-gray-500">Stuur je exacte Thuisbezorgd-link door, dan zet ik hem hier direct live.</p>
    </div>
  </section>
</BaseLayout>
