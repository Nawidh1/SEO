---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import InfoCard from '../components/InfoCard.astro';
import Card from '../components/Card.astro';

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Restaurant',
      name: 'Brasserie Pizzeria Hama',
      url: 'https://nawidh1.github.io/SEO',
      telephone: '+31 115 691 219',
      email: 'info@hama-terneuzen.example',
      image: 'https://nawidh1.github.io/SEO/og/home.jpg',
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Axelsestraat 15',
        addressLocality: 'Terneuzen',
        addressRegion: 'Zeeland',
        postalCode: '4537 AA',
        addressCountry: 'NL',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: 51.3349,
        longitude: 3.8276,
      },
      openingHoursSpecification: [
        { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday'], opens: '12:00', closes: '22:00' },
        { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Friday', 'Saturday'], opens: '12:00', closes: '23:00' },
        { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '13:00', closes: '21:00' },
      ],
      sameAs: ['https://www.facebook.com/', 'https://www.instagram.com/'],
      areaServed: 'Terneuzen and surrounding Zeeland region',
      hasMap: 'https://maps.google.com/?q=Axelsestraat+15,+4537+AA+Terneuzen',
    },
    {
      '@type': 'WebSite',
      name: 'Brasserie Pizzeria Hama',
      url: 'https://nawidh1.github.io/SEO',
    },
  ],
};
---

<BaseLayout title="Brasserie Pizzeria Hama | Restaurant Terneuzen" description="Modern brasserie and pizzeria in Terneuzen with dine-in, catering, and private events." schema={schema} ogImage="https://nawidh1.github.io/SEO/og/home.jpg">
  <Hero title="Modern Brasserie and Pizzeria in Terneuzen" subtitle="Fresh pizza, quality classics, and a warm atmosphere for lunch, dinner, and group nights." cta={{ label: 'Book a Table', href: '/contact' }} ctaSecondary={{ label: 'See Menu', href: '/menu' }} />

  <section class="section-padding -mt-6 lg:-mt-10">
    <div class="container-wide grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <InfoCard label="Open" value="7 Days" detail="Lunch and dinner" />
      <InfoCard label="Address" value="Axelsestraat 15" detail="4537 AA Terneuzen" />
      <InfoCard label="Phone" value="0115 691 219" detail="Fast reservation support" />
      <InfoCard label="Service" value="Dine-in + Pickup" detail="Catering available" />
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-wide">
      <SectionHeading title="What You Can Expect" subtitle="Simple menu choices, great flavor, and quick, friendly service." align="center" />
      <div class="mt-10 grid gap-6 md:grid-cols-3">
        <Card title="Signature Pizza" text="Stone-baked pizzas with classic and seasonal toppings." href="/menu" />
        <Card title="Private Events" text="Flexible space for birthdays, team dinners, and celebrations." href="/private-events" />
        <Card title="Catering" text="Reliable group food with easy planning and pickup options." href="/catering" />
      </div>
    </div>
  </section>

  <section class="section-padding">
    <div class="container-wide grid gap-6 lg:grid-cols-2">
      <article class="animate-enter rounded-2xl border border-gray-100 bg-white p-7 shadow-sm">
        <h2 class="text-3xl">Visit Us Today</h2>
        <address class="not-italic mt-4 space-y-1 text-gray-700">
          <p>Brasserie Pizzeria Hama</p>
          <p>Axelsestraat 15, 4537 AA Terneuzen</p>
          <p><a class="text-sky-700 hover:underline" href="tel:+31115691219">0115 691 219</a></p>
        </address>
        <div class="mt-5 flex h-44 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">
          Google Map embed placeholder
        </div>
      </article>

      <article class="animate-enter rounded-2xl border border-sky-100 bg-gradient-to-br from-sky-50 via-white to-warm-100 p-7 shadow-sm">
        <h2 class="text-3xl">Quick Actions</h2>
        <p class="mt-3 text-gray-700">Book, order, or share in seconds.</p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <a href="/contact" class="btn-primary">Reserve Now</a>
          <a href="/order-online" class="btn-outline">Bestel via Thuisbezorgd</a>
          <a target="_blank" rel="noopener noreferrer" href="https://www.facebook.com/sharer/sharer.php?u=https://nawidh1.github.io/SEO/" class="btn-outline">Share Facebook</a>
          <a target="_blank" rel="noopener noreferrer" href="https://wa.me/?text=Brasserie%20Pizzeria%20Hama%20https://nawidh1.github.io/SEO/" class="btn-outline">Share WhatsApp</a>
        </div>
      </article>
    </div>
  </section>

  <section class="section-padding bg-white">
    <div class="container-narrow text-center">
      <h2 class="text-3xl">Ready for Your Next Meal?</h2>
      <p class="mt-3 text-gray-700">Enjoy quality pizza and brasserie favorites in a clean, modern setting.</p>
      <div class="mt-6 flex flex-col justify-center gap-4 sm:flex-row">
        <a href="/menu" class="btn-primary">Browse Menu</a>
        <a href="https://maps.google.com/?q=Axelsestraat+15,+4537+AA+Terneuzen" target="_blank" rel="noopener noreferrer" class="btn-outline">Open in Google Maps</a>
      </div>
    </div>
  </section>
</BaseLayout>
