---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Brasserie Pizzeria Hama" description="The page you are looking for could not be found." robots="noindex, nofollow">
  <section class="section-padding">
    <div class="container-narrow text-center">
      <h1 class="text-4xl">Page Not Found</h1>
      <p class="mt-4 text-gray-700">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="btn-primary mt-6">Return to Homepage</a>
      <div class="mt-6 flex justify-center gap-4">
        <a href="/menu" class="text-sky-700 hover:underline">View Menu</a>
        <a href="/contact" class="text-sky-700 hover:underline">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>
