---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout title="Gallery | Brasserie Pizzeria Hama" description="Preview the dining atmosphere, signature dishes, and private event setup at Brasserie Pizzeria Hama." ogImage="https://hama-terneuzen.example.com/og/gallery.jpg">
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Gallery', href: '/gallery' }]} />
  <PageHero title="Gallery" subtitle="A preview of our dining room, dishes, and event atmosphere." />
  <section class="section-padding">
    <div class="container-wide grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="flex h-52 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">Dining room photo placeholder</div>
      <div class="flex h-52 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">Pizza close-up placeholder</div>
      <div class="flex h-52 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">Outdoor seating placeholder</div>
      <div class="flex h-52 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">Family dining placeholder</div>
      <div class="flex h-52 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">Chef plating placeholder</div>
      <div class="flex h-52 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">Private event setup placeholder</div>
    </div>
  </section>
</BaseLayout>
