---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout title="Contact | Brasserie Pizzeria Hama" description="Contact Brasserie Pizzeria Hama for reservations, catering, and private event inquiries in Terneuzen." ogImage="https://hama-terneuzen.example.com/og/contact.jpg">
  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Contact', href: '/contact' }]} />
  <PageHero title="Contact Us" subtitle="Reserve a table, ask a question, or request catering information." />
  <section class="section-padding">
    <div class="container-wide grid gap-10 lg:grid-cols-2">
      <article>
        <h2 class="text-2xl">Send a Message</h2>
        <form action="#" method="post" class="mt-5 space-y-4 rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <p class="text-sm text-gray-500">Form backend placeholder: configure Formspree, Netlify Forms, or another provider.</p>
          <div>
            <label for="name" class="block text-sm font-medium text-gray-700">Name</label>
            <input id="name" name="name" type="text" required class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-3" />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
            <input id="email" name="email" type="email" required class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-3" />
          </div>
          <div>
            <label for="subject" class="block text-sm font-medium text-gray-700">Subject</label>
            <input id="subject" name="subject" type="text" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-3" />
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-gray-700">Message</label>
            <textarea id="message" name="message" required rows="5" class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-3"></textarea>
          </div>
          <button type="submit" class="btn-primary">Submit</button>
        </form>
      </article>

      <article>
        <h2 class="text-2xl">Visit Brasserie Pizzeria Hama</h2>
        <address class="not-italic mt-4 space-y-1 text-gray-700">
          <p>Axelsestraat 15</p>
          <p>4537 AA Terneuzen</p>
          <p>Phone: <a href="tel:+31115691219" class="text-sky-700 hover:underline">0115 691 219</a></p>
          <p>Email: <a href="mailto:info@hama-terneuzen.example" class="text-sky-700 hover:underline">info@hama-terneuzen.example</a></p>
        </address>
        <div class="mt-6 rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <h3 class="text-xl">Opening Hours</h3>
          <ul class="mt-3 space-y-1 text-sm text-gray-700">
            <li>Mon-Thu: 12:00 - 22:00</li>
            <li>Fri-Sat: 12:00 - 23:00</li>
            <li>Sunday: 13:00 - 21:00</li>
          </ul>
        </div>
        <div class="mt-6 flex h-56 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">Map placeholder - embed Google Map here</div>
      </article>
    </div>
  </section>
</BaseLayout>
