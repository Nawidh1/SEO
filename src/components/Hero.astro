---
interface Props {
  title: string;
  subtitle: string;
  cta: { label: string; href: string };
  ctaSecondary: { label: string; href: string };
  size?: 'default' | 'compact';
}

const { title, subtitle, cta, ctaSecondary, size = 'default' } = Astro.props;
---

<section class={`relative overflow-hidden bg-gradient-to-b from-sky-50 via-white to-warm-100 ${size === 'default' ? 'section-padding' : 'px-4 py-12 sm:px-6 lg:px-8 lg:py-16'}`}>
  <div class="animate-float absolute -left-24 top-10 h-64 w-64 rounded-full bg-sky-100/80 blur-3xl" aria-hidden="true"></div>
  <div class="animate-pulse-soft absolute -right-24 bottom-0 h-72 w-72 rounded-full bg-warm-200/80 blur-3xl" aria-hidden="true"></div>

  <div class="container-wide relative grid items-center gap-10 lg:grid-cols-2">
    <div class="animate-enter">
      <p class="inline-flex rounded-full border border-sky-100 bg-white px-4 py-2 text-xs font-semibold uppercase tracking-wide text-sky-700">Top Rated Local Restaurant</p>
      <h1 class="mt-5 text-4xl font-semibold leading-tight sm:text-5xl">{title}</h1>
      <p class="mt-5 max-w-xl text-base text-gray-700 sm:text-lg">{subtitle}</p>
      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a href={cta.href} class="btn-primary">{cta.label}</a>
        <a href={ctaSecondary.href} class="btn-outline">{ctaSecondary.label}</a>
      </div>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-gray-600">
        <span class="rounded-full bg-white px-3 py-2 shadow-sm">Fresh daily ingredients</span>
        <span class="rounded-full bg-white px-3 py-2 shadow-sm">Fast table service</span>
        <span class="rounded-full bg-white px-3 py-2 shadow-sm">Family friendly</span>
      </div>
    </div>

    <div class="animate-enter rounded-2xl border border-white/70 bg-white p-6 shadow-xl">
      <div class="grid gap-4 sm:grid-cols-2">
        <div class="rounded-xl bg-sky-50 p-4">
          <p class="text-xs uppercase tracking-wide text-sky-700">Today</p>
          <p class="mt-2 text-xl font-semibold text-navy-800">Open 12:00 - 22:00</p>
        </div>
        <div class="rounded-xl bg-warm-100 p-4">
          <p class="text-xs uppercase tracking-wide text-sky-700">Call</p>
          <p class="mt-2 text-xl font-semibold text-navy-800">0115 691 219</p>
        </div>
      </div>
      <div class="mt-4 flex h-48 items-center justify-center rounded-xl border-2 border-dashed border-gray-300 bg-gray-50 text-sm text-gray-500">
        Featured dish photo placeholder
      </div>
    </div>
  </div>
</section>
