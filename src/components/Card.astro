---
interface Props {
  title: string;
  text: string;
  href?: string;
}

const { title, text, href } = Astro.props;
---

<article class={`rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition ${href ? 'hover:-translate-y-0.5 hover:shadow-md' : ''}`}>
  <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-full bg-sky-100" aria-hidden="true">
    <svg class="h-5 w-5 text-sky-700" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 4v16M4 12h16" stroke-width="2" stroke-linecap="round" /></svg>
  </div>
  <h3 class="text-xl">{title}</h3>
  <p class="mt-3 text-sm text-gray-700">{text}</p>
  {href && <a class="mt-4 inline-block text-sm font-semibold text-sky-700 hover:underline" href={href}>Learn more</a>}
</article>
