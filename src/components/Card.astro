---
interface Props {
  title: string;
  text: string;
  href?: string;
}

const { title, text, href } = Astro.props;
---

<article class={`animate-enter surface-card p-6 transition duration-300 ${href ? 'hover:-translate-y-1 hover:shadow-xl hover:ring-1 hover:ring-sky-200' : ''}`}>
  <div class="mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl bg-sky-100" aria-hidden="true">
    <svg class="h-5 w-5 text-sky-700" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 4v16M4 12h16" stroke-width="2" stroke-linecap="round" /></svg>
  </div>
  <h3 class="text-xl">{title}</h3>
  <p class="mt-3 text-sm leading-6 text-gray-700">{text}</p>
  {href && <a class="mt-5 inline-block text-sm font-semibold text-sky-700 hover:text-sky-800 hover:underline" href={href}>Explore</a>}
</article>
