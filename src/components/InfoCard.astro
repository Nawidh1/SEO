---
interface Props {
  label: string;
  value: string;
  detail: string;
}

const { label, value, detail } = Astro.props;
---

<article class="animate-enter surface-card p-6 text-center transition duration-300 hover:-translate-y-1 hover:shadow-xl">
  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">{label}</p>
  <p class="mt-2 text-2xl font-semibold text-navy-800">{value}</p>
  <p class="mt-2 text-sm text-gray-700">{detail}</p>
</article>
