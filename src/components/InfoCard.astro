---
interface Props {
  label: string;
  value: string;
  detail: string;
}

const { label, value, detail } = Astro.props;
---

<article class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
  <p class="text-sm font-semibold uppercase tracking-wide text-sky-700">{label}</p>
  <p class="mt-2 text-2xl font-semibold text-navy-800">{value}</p>
  <p class="mt-2 text-sm text-gray-700">{detail}</p>
</article>
