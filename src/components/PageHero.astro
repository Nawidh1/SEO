---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<section class="bg-gradient-to-b from-sky-50 via-white to-warm-100 px-4 py-12 sm:px-6 lg:px-8">
  <div class="container-wide">
    <h1 class="text-3xl sm:text-4xl">{title}</h1>
    {subtitle && <p class="mt-3 max-w-3xl text-gray-700">{subtitle}</p>}
  </div>
</section>
